distrodate() {
  \ls -lct /etc | tail -1 | awk '{print $6, $7, $8}'
}
heure() {
  echo "$(\date '+%T'), le $(date '+%A %d %B %Y')"
}
lessc() {
  \bat --color=always --plain "$1" | \less -F -R
}
nocomm() {
  \rg -v "^\s*(#|//|;)" --color=never "$1" | bat -p --file-name "$1"
}
ramfree() {
  while true; do
    memfree_kb=$(grep '^MemFree' /proc/meminfo | awk '{print $2}')
    memfree_mo=$((memfree_kb / 1024))
    echo -e "MemFree: \e[32m ${memfree_mo} Mo\e[0m"
    sleep 2
  done
}
ramavail() {
  while true; do
    memavail_kb=$(grep '^MemAvailable' /proc/meminfo | awk '{print $2}')
    memavail_mo=$((memavail_kb / 1024))
    echo -e "MemAvailable: \e[32m ${memavail_mo} Mo\e[0m"
    sleep 2
  done
}
logfwRT() {
  journalctl -f -n50 |
    awk '/filter_IN/ {
      gsub(/ MAC=[^ ]*/, "");
      gsub(/ LEN=[^ ]*/, "");
      gsub(/ TOS=[^ ]*/, "");
      gsub(/ PREC=[^ ]*/, "");
      gsub(/ ID=[^ ]*/, "");
      gsub(/ TTL=[^ ]*/, "");
      gsub(/ DF[^ ]*/, "");
      gsub(/ OUT=[^ ]*/, "");
      gsub(/ TC=[^ ]*/, "");
      gsub(/ HOPLIMIT=[^ ]*/, "");
      gsub(/ FLOWLBL=[^ ]*/, "");
      printf "%-2s %-8s %-15s %-15s %-15s %-15s %-15s %-45s %-45s \n",
             $2, $1, $3, $6, $9, $10, $11, $7, $8
    }'
}
logfw() {
  journalctl |
    awk '/filter_IN/ {
      gsub(/ MAC=[^ ]*/, "");
      gsub(/ LEN=[^ ]*/, "");
      gsub(/ TOS=[^ ]*/, "");
      gsub(/ PREC=[^ ]*/, "");
      gsub(/ ID=[^ ]*/, "");
      gsub(/ TTL=[^ ]*/, "");
      gsub(/ DF[^ ]*/, "");
      gsub(/ OUT=[^ ]*/, "");
      gsub(/ TC=[^ ]*/, "");
      gsub(/ HOPLIMIT=[^ ]*/, "");
      gsub(/ FLOWLBL=[^ ]*/, "");
      printf "%-2s %-8s %-15s %-15s %-15s %-15s %-15s %-45s %-45s \n",
             $2, $1, $3, $6, $9, $10, $11, $7, $8
    }' |
    grep -E "SRC=|DST=|SPT=|DPT="
}
logerror() { # erreurs dédupliquées sur le boot en cours
  journalctl --no-hostname -b 0 -p3 --no-pager -q 2>&1 |
    awk '{key=substr($0,index($0,$4)); if(!seen[key]++) print $0}'
}
help() { # help coloré
    "$@" --help 2>&1 | bathelp
}
scripts() { # menu de lancement des scripts perso direct ou via doas avec preview colorée
    fd . ~/.local/bin | fzf --preview 'bat -p --color=always {}' \
                            --bind 'ctrl-y:execute(doas {})+accept' \
                            --bind 'enter:execute({})+accept' \
                            --header 'ENTER=exec CTRL-Y=exec avec doas'
}
myip() {
  local ipv4 ipv6
  ipv4=$(curl --silent -4 https://icanhazip.com/)
  ipv6=$(curl --silent -6 https://icanhazip.com/)
  [[ -z $ipv4 ]] && echo "No IPv4 internet connectivity" || echo "IPv4: $ipv4"
  [[ -z $ipv6 ]] &&	echo "No IPv6 internet connectivity" || echo "IPv6: $ipv6"
}
