{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "buffer_line_height": "standard",
  "text_rendering_mode": "platform_default",
  "ui_font_size": 18.0,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte (lavender)",
    "dark": "Catppuccin Mocha (lavender)"
  },
  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 18.0,
  "ui_font_weight": 400.0,
  "ui_font_family": ".ZedMono",
  "buffer_font_size": 18.0,
  "disable_ai": true,
  "buffer_font_family": ".ZedMono",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "Iosevka Nerd Font Mono",
  },
  "auto_install_extensions": {
    "basher": true,
    "catppuccin-icons": true,
    "toml": true,
  },
  "auto_update": true,
}
